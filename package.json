{
  "name": "educoder-local-oj-extension",
  "displayName": "Educoder Local OJ Extension",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "engines": {
    "vscode": "^1.90.0"
  },
  "activationEvents": [
    "onCommand:educoderLocalOj.syncCurrentCollection",
    "onCommand:educoderLocalOj.openTask",
    "onCommand:educoderLocalOj.runLocalJudge",
    "onCommand:educoderLocalOj.rerunFailedCases",
    "onCommand:educoderLocalOj.runOfficialJudge",
    "onCommand:educoderLocalOj.forceRunOfficialJudge",
    "onCommand:educoderLocalOj.rollbackTemplate",
    "onCommand:educoderLocalOj.rollbackPassed"
  ],
  "main": "./dist/src/extension.js",
  "contributes": {
    "commands": [
      { "command": "educoderLocalOj.syncCurrentCollection", "title": "Sync Current Collection" },
      { "command": "educoderLocalOj.openTask", "title": "Open Task" },
      { "command": "educoderLocalOj.runLocalJudge", "title": "Run Local Judge" },
      { "command": "educoderLocalOj.rerunFailedCases", "title": "Rerun Failed Cases" },
      { "command": "educoderLocalOj.runOfficialJudge", "title": "Run Official Judge" },
      { "command": "educoderLocalOj.forceRunOfficialJudge", "title": "Force Run Official Judge" },
      { "command": "educoderLocalOj.rollbackTemplate", "title": "Rollback Template" },
      { "command": "educoderLocalOj.rollbackPassed", "title": "Rollback Passed" }
    ]
  },
  "scripts": {
    "build": "tsc -p . && node -e \"const fs=require('fs');const p=require('./package.json').main.replace(/^\\.\\//,'');if(!fs.existsSync(p)){console.error('Missing main output: '+p);process.exit(1)}\"",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  }
}
