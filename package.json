{
  "name": "educoder-local-oj-extension",
  "displayName": "Educoder Local OJ Extension",
  "version": "0.0.1",
  "private": true,
  "description": "Sync Educoder shixun_homework collections into a local OJ workflow inside VS Code.",
  "publisher": "young-lab",
  "license": "MIT",
  "categories": ["Other"],
  "keywords": ["educoder", "oj", "vscode", "judge"],
  "type": "module",
  "engines": {
    "vscode": "^1.90.0"
  },
  "activationEvents": [
    "onCommand:educoderLocalOj.syncCurrentCollection",
    "onCommand:educoderLocalOj.openTask",
    "onCommand:educoderLocalOj.runLocalJudge",
    "onCommand:educoderLocalOj.rerunFailedCases",
    "onCommand:educoderLocalOj.runOfficialJudge",
    "onCommand:educoderLocalOj.forceRunOfficialJudge",
    "onCommand:educoderLocalOj.rollbackTemplate",
    "onCommand:educoderLocalOj.rollbackPassed"
  ],
  "main": "./dist/src/extension.js",
  "repository": {
    "type": "git",
    "url": "https://example.com/young/educoder-local-oj-extension.git"
  },
  "contributes": {
    "commands": [
      { "command": "educoderLocalOj.syncCurrentCollection", "title": "Educoder Local OJ: Sync Current Collection" },
      { "command": "educoderLocalOj.openTask", "title": "Educoder Local OJ: Open Task" },
      { "command": "educoderLocalOj.runLocalJudge", "title": "Educoder Local OJ: Run Local Judge" },
      { "command": "educoderLocalOj.rerunFailedCases", "title": "Educoder Local OJ: Rerun Failed Cases" },
      { "command": "educoderLocalOj.runOfficialJudge", "title": "Educoder Local OJ: Run Official Judge" },
      { "command": "educoderLocalOj.forceRunOfficialJudge", "title": "Educoder Local OJ: Force Run Official Judge" },
      { "command": "educoderLocalOj.rollbackTemplate", "title": "Educoder Local OJ: Rollback Template" },
      { "command": "educoderLocalOj.rollbackPassed", "title": "Educoder Local OJ: Rollback Passed" }
    ]
  },
  "scripts": {
    "build": "tsc -p . && node -e \"const fs=require('fs');const p=require('./package.json').main.replace(/^\\.\\//,'');if(!fs.existsSync(p)){console.error('Missing main output: '+p);process.exit(1)}\"",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  }
}
